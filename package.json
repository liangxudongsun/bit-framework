{
  "name": "@gongxh/bit-framework",
  "version": "0.0.10",
  "private": true,
  "description": "bit-framework monorepo - Cocos Creator 游戏框架",
  "scripts": {
    "clean": "pnpm -r --parallel clean",

    "build": "pnpm -r --filter='!bit-creator' build",
    "build:core": "pnpm --filter @gongxh/bit-core build",
    "build:ui": "pnpm --filter @gongxh/bit-ui build",
    "build:ecs": "pnpm --filter @gongxh/bit-ecs build",
    "build:event": "pnpm --filter @gongxh/bit-event build",
    "build:net": "pnpm --filter @gongxh/bit-net build",
    "build:quadtree": "pnpm --filter @gongxh/bit-quadtree build",
    "build:assets": "pnpm --filter @gongxh/bit-assets build",
    "build:behaviortree": "pnpm --filter @gongxh/bit-behaviortree build",
    "build:ec": "pnpm --filter @gongxh/bit-ec build",
    "build:condition": "pnpm --filter @gongxh/bit-condition build",
    "build:minigame": "pnpm --filter @gongxh/bit-minigame build",
    "build:hotupdate": "pnpm --filter @gongxh/bit-hotupdate build",

    "build:all": "pnpm build:core && pnpm build:ui && pnpm build:ecs && pnpm build:event && pnpm build:net && pnpm build:quadtree && pnpm build:assets && pnpm build:behaviortree && pnpm build:ec && pnpm build:condition && pnpm build:minigame && pnpm build:hotupdate && pnpm copy:dts",

    "copy:dts": "cp bit-core/dist/bit-core.d.ts bit-ui/dist/bit-ui.d.ts bit-ecs/dist/bit-ecs.d.ts bit-event/dist/bit-event.d.ts bit-net/dist/bit-net.d.ts bit-quadtree/dist/bit-quadtree.d.ts bit-assets/dist/bit-assets.d.ts bit-behaviortree/dist/bit-behaviortree.d.ts bit-ec/dist/bit-ec.d.ts bit-condition/dist/bit-condition.d.ts bit-minigame/dist/bit-minigame.d.ts bit-hotupdate/dist/bit-hotupdate.d.ts /Users/gongxh/work/kunpo-lib/bit-framework-mcp/dts/framework/",

    "dev:core": "pnpm --filter @gongxh/bit-core build --watch",
    "dev:ui": "pnpm --filter @gongxh/bit-ui build --watch",

    "publish:core": "pnpm --filter @gongxh/bit-core publish",
    "publish:ui": "pnpm --filter @gongxh/bit-ui publish",
    "publish:ecs": "pnpm --filter @gongxh/bit-ecs publish",
    "publish:event": "pnpm --filter @gongxh/bit-event publish",
    "publish:net": "pnpm --filter @gongxh/bit-net publish",
    "publish:quadtree": "pnpm --filter @gongxh/bit-quadtree publish",
    "publish:assets": "pnpm --filter @gongxh/bit-assets publish",
    "publish:behaviortree": "pnpm --filter @gongxh/bit-behaviortree publish",
    "publish:ec": "pnpm --filter @gongxh/bit-ec publish",
    "publish:condition": "pnpm --filter @gongxh/bit-condition publish",
    "publish:minigame": "pnpm --filter @gongxh/bit-minigame publish",
    "publish:hotupdate": "pnpm --filter @gongxh/bit-hotupdate publish",

    "publish:all": "pnpm publish:core && pnpm publish:ui && pnpm publish:ecs && pnpm publish:event && pnpm publish:net && pnpm publish:quadtree && pnpm publish:assets && pnpm publish:behaviortree && pnpm publish:ec && pnpm publish:condition && pnpm publish:minigame && pnpm publish:hotupdate",

    "version:patch": "pnpm -r --filter='!bit-creator' exec npm version patch",
    "version:minor": "pnpm -r --filter='!bit-creator' exec npm version minor",
    "version:major": "pnpm -r --filter='!bit-creator' exec npm version major"
  },
  "keywords": [
    "bit-framework",
    "cocos",
    "cocos-creator",
    "monorepo",
    "game-framework"
  ],
  "author": "bit老宫",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gongxh0901/bit-framework.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@cocos/creator-types": "^3.8.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2"
  }
}

